---
const pathname = Astro.url.pathname;
const appStoreURL = "https://apps.apple.com/us/app/pitch31-card-game/id6758834923";

const navLinks = [
  { label: "Home", href: "/" },
  { label: "Blog", href: "/blog" },
  { label: "How to Play", href: "/how-to-play" },
  { label: "About", href: "/about" },
];

function isActive(href: string): boolean {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<header class="sticky top-0 z-50 bg-surface border-b border-border">
  <nav
    class="mx-auto flex max-w-6xl flex-wrap items-center justify-between gap-x-6 gap-y-3 px-5 py-3 sm:px-8"
    aria-label="Main navigation"
  >
    <!-- Site name -->
    <a
      href="/"
      class="text-xl font-bold text-primary no-underline hover:text-primary-hover sm:text-2xl"
    >
      Pitch31
    </a>

    <!-- Nav links + CTA -->
    <div class="flex flex-wrap items-center gap-x-5 gap-y-2 sm:gap-x-7">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class:list={[
            "inline-flex min-h-[48px] items-center text-base font-medium no-underline transition-colors sm:text-lg",
            isActive(link.href)
              ? "text-primary border-b-2 border-primary font-semibold"
              : "text-text hover:text-primary",
          ]}
          aria-current={isActive(link.href) ? "page" : undefined}
        >
          {link.label}
        </a>
      ))}

      <a
        href={appStoreURL}
        class="btn-primary ml-1 !min-h-[48px] !px-5 !py-2 !text-base sm:!text-lg"
        target="_blank"
        rel="noopener noreferrer"
      >
        Download
      </a>
    </div>
  </nav>
</header>
