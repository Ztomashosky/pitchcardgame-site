---
import BaseLayout from "./BaseLayout.astro";

interface Props {
  title: string;
  description: string;
  pubDate: Date;
  updatedDate?: Date;
  heroImage?: string;
  tags?: string[];
}

const { title, description, pubDate, updatedDate, heroImage, tags = [] } =
  Astro.props;

const formattedPubDate = pubDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const formattedUpdatedDate = updatedDate
  ? updatedDate.toLocaleDateString("en-US", {
      year: "numeric",
      month: "long",
      day: "numeric",
    })
  : null;

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: title,
  description: description,
  image: heroImage
    ? new URL(heroImage, "https://pitch31.com").toString()
    : undefined,
  datePublished: pubDate.toISOString(),
  dateModified: updatedDate ? updatedDate.toISOString() : pubDate.toISOString(),
  author: {
    "@type": "Organization",
    name: "Pitch31",
    url: "https://pitch31.com",
  },
  publisher: {
    "@type": "Organization",
    name: "Pitch31",
    url: "https://pitch31.com",
  },
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": new URL(Astro.url.pathname, "https://pitch31.com").toString(),
  },
};
---

<BaseLayout title={title} description={description} image={heroImage}>
  <Fragment slot="head">
    <script
      type="application/ld+json"
      set:html={JSON.stringify(jsonLd)}
    />
  </Fragment>

  <article class="max-w-3xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <!-- Hero Image -->
    {
      heroImage && (
        <img
          src={heroImage}
          alt={title}
          class="w-full rounded-xl mb-8 shadow-sm"
        />
      )
    }

    <!-- Title -->
    <h1
      class="font-['Playfair_Display'] text-3xl sm:text-4xl lg:text-5xl font-bold text-[#2D2A26] leading-tight mb-4"
    >
      {title}
    </h1>

    <!-- Date Info -->
    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-[#2D2A26]/60 mb-4">
      <time datetime={pubDate.toISOString()}>
        {formattedPubDate}
      </time>
      {
        formattedUpdatedDate && (
          <span class="italic">Last updated: {formattedUpdatedDate}</span>
        )
      }
    </div>

    <!-- Tags -->
    {
      tags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-8">
          {tags.map((tag) => (
            <span class="inline-block px-3 py-1 text-xs font-medium rounded-full bg-[#F0EBE1] text-[#1B6B4A]">
              {tag}
            </span>
          ))}
        </div>
      )
    }

    <!-- Divider -->
    <hr class="border-[#F0EBE1] mb-10" />

    <!-- Article Content -->
    <div class="prose prose-lg max-w-none
      prose-headings:font-['Playfair_Display'] prose-headings:text-[#2D2A26]
      prose-p:text-[#2D2A26]/85 prose-p:leading-relaxed
      prose-a:text-[#1B6B4A] prose-a:underline prose-a:decoration-[#1B6B4A]/30 hover:prose-a:decoration-[#1B6B4A]
      prose-strong:text-[#2D2A26]
      prose-blockquote:border-l-[#C4922A] prose-blockquote:text-[#2D2A26]/70
      prose-li:text-[#2D2A26]/85"
    >
      <slot />
    </div>

    <!-- Bottom CTA -->
    <div class="mt-16 p-8 sm:p-10 bg-[#F0EBE1] rounded-2xl text-center">
      <h2
        class="font-['Playfair_Display'] text-2xl sm:text-3xl font-bold text-[#2D2A26] mb-3"
      >
        Ready to play?
      </h2>
      <p class="text-[#2D2A26]/70 mb-6 max-w-md mx-auto">
        Download Pitch31 and experience 31-Point Partnership Pitch on your iPhone or iPad.
      </p>
      <a
        href="https://apps.apple.com/us/app/pitch31-card-game/id6758834923"
        class="inline-flex items-center gap-2 px-6 py-3 bg-[#1B6B4A] text-white font-semibold rounded-xl shadow-sm hover:bg-[#155639] transition-colors"
      >
        <svg class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
        </svg>
        Download on the App Store
      </a>
    </div>
  </article>
</BaseLayout>
