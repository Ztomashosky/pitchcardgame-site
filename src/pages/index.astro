---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getCollection } from "astro:content";

const appStoreURL = "https://apps.apple.com/us/app/pitch31-card-game/id6758834923";

const allPosts = await getCollection("blog");
const latestPosts = allPosts
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<BaseLayout
  title="Pitch31 — 31-Point Partnership Card Game"
  description="The only app with correct 31-point partnership Pitch rules. Smart AI opponents, large readable cards, and no sign-up required. Free on iPhone."
>
  <!-- ============================================================
       HERO
       ============================================================ -->
  <section class="bg-surface">
    <div class="mx-auto max-w-4xl px-5 py-20 text-center sm:px-8 sm:py-28">
      <h1 class="font-serif text-[clamp(2.25rem,5vw,3.5rem)] font-bold leading-[1.12] text-heading">
        Play Pitch Anytime.<br />Even Without Four People.
      </h1>

      <p class="mx-auto mt-5 max-w-2xl text-lg leading-relaxed text-text/80 sm:text-xl">
        The only app with correct 31-point partnership rules. Smart AI opponents. No sign-up required.
      </p>

      <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
        <a
          href={appStoreURL}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary !text-lg"
        >
          Download Free
        </a>
        <a
          href="/blog/how-to-play-31-point-pitch/"
          class="btn-secondary !text-lg"
        >
          Learn the Rules
        </a>
      </div>

      <p class="mt-5 text-sm text-text/55">
        Free on iPhone. No account needed.
      </p>
    </div>
  </section>

  <!-- ============================================================
       FEATURES
       ============================================================ -->
  <section class="bg-bg">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        <!-- Card 1 -->
        <div class="card">
          <h3 class="mb-3 text-xl font-bold text-heading sm:text-2xl">The Right Rules</h3>
          <p class="m-0 text-base leading-relaxed text-text/80 sm:text-lg">
            31-point partnership Pitch with Off-Jacks, Jokers, protected 2 of trump, and Shoot the Moon. Every rule correct.
          </p>
        </div>

        <!-- Card 2 -->
        <div class="card">
          <h3 class="mb-3 text-xl font-bold text-heading sm:text-2xl">Smart AI</h3>
          <p class="m-0 text-base leading-relaxed text-text/80 sm:text-lg">
            Your AI partner and opponents bid strategically and play to win. They protect the 3, guard their points, and know when to shoot the moon.
          </p>
        </div>

        <!-- Card 3 -->
        <div class="card">
          <h3 class="mb-3 text-xl font-bold text-heading sm:text-2xl">Built for You</h3>
          <p class="m-0 text-base leading-relaxed text-text/80 sm:text-lg">
            Large, readable cards. Clean table. No flashing ads. No confusing currencies. Just cards, played right.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- ============================================================
       STORY
       ============================================================ -->
  <section class="bg-surface">
    <div class="mx-auto max-w-3xl px-5 py-16 text-center sm:px-8 sm:py-24">
      <h2 class="font-serif text-[clamp(1.65rem,3.5vw,2.5rem)] font-bold text-heading">
        Built for My Grandmother
      </h2>

      <p class="mx-auto mt-5 max-w-2xl text-base leading-relaxed text-text/80 sm:text-lg">
        I built Pitch31 for my grandmother. At 88, she still loves Pitch, but after my grandfather passed, their regular foursome was gone. She didn't want flashy animations or loud ads. She just wanted to play cards. Now she plays every day.
      </p>

      <div class="mt-9">
        <a
          href={appStoreURL}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary !text-lg"
        >
          Download Pitch31
        </a>
      </div>
    </div>
  </section>

  <!-- ============================================================
       BLOG PREVIEW
       ============================================================ -->
  <section class="bg-bg">
    <div class="mx-auto max-w-6xl px-5 py-16 sm:px-8 sm:py-24">
      <h2 class="mb-10 text-center font-serif text-[clamp(1.65rem,3.5vw,2.5rem)] font-bold text-heading">
        Learn Pitch
      </h2>

      <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
        {latestPosts.map((post) => (
          <a href={`/blog/${post.id}/`} class="card block no-underline">
            <h3 class="mb-2 text-lg font-bold text-heading sm:text-xl">
              {post.data.title}
            </h3>
            <p class="m-0 text-base leading-relaxed text-text/70">
              {post.data.description}
            </p>
            <span class="mt-4 inline-block text-sm font-semibold text-primary">
              Read more &rarr;
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============================================================
       FINAL CTA
       ============================================================ -->
  <section class="bg-primary">
    <div class="mx-auto max-w-4xl px-5 py-16 text-center sm:px-8 sm:py-20">
      <h2 class="font-serif text-[clamp(1.65rem,3.5vw,2.5rem)] font-bold text-white">
        Ready to Play?
      </h2>

      <div class="mt-8">
        <a
          href={appStoreURL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex min-h-[48px] items-center gap-2 rounded-xl border-2 border-white bg-white px-8 py-3 text-lg font-semibold text-primary no-underline shadow-sm transition-all hover:bg-white/90 hover:shadow-md"
        >
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M18.71 19.5c-.83 1.24-1.71 2.45-3.05 2.47-1.34.03-1.77-.79-3.29-.79-1.53 0-2 .77-3.27.82-1.31.05-2.3-1.32-3.14-2.53C4.25 17 2.94 12.45 4.7 9.39c.87-1.52 2.43-2.48 4.12-2.51 1.28-.02 2.5.87 3.29.87.78 0 2.26-1.07 3.8-.91.65.03 2.47.26 3.64 1.98-.09.06-2.17 1.28-2.15 3.81.03 3.02 2.65 4.03 2.68 4.04-.03.07-.42 1.44-1.38 2.83M13 3.5c.73-.83 1.94-1.46 2.94-1.5.13 1.17-.34 2.35-1.04 3.19-.69.85-1.83 1.51-2.95 1.42-.15-1.15.41-2.35 1.05-3.11z" />
          </svg>
          Download on the App Store
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
